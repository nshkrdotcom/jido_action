        "date": "2026-03-28",
        "file": ".spec/decisions/jido_action.spec_migration.md",
        "id": "jido_action.spec_migration",
        "status": "accepted",
        "title": "Adopt subsystem-based Spec Led subjects"
      }
    ]
  },
  "findings": [],
  "index": {
    "exceptions": [],
    "requirements": [
      {
        "file": ".spec/specs/action.spec.md",
        "id": "jido_action.action.metadata_contract",
        "priority": "must",
        "stability": "stable",
        "statement": "use Jido.Action shall define named action modules that expose action metadata, declared schemas, and JSON-friendly metadata accessors.",
        "subject_id": "jido_action.action"
      },
      {
        "file": ".spec/specs/action.spec.md",
        "id": "jido_action.action.schema_validation",
        "priority": "must",
        "stability": "stable",
        "statement": "Actions shall validate declared input and output schemas while preserving unspecified fields so composed actions can pass through extra data and lifecycle callbacks can adjust results.",
        "subject_id": "jido_action.action"
      },
      {
        "file": ".spec/specs/action.spec.md",
        "id": "jido_action.action.tool_bridge",
        "priority": "should",
        "stability": "evolving",
        "statement": "Actions shall convert declared schemas into AI tool parameter schemas and coerce known tool inputs without discarding unknown keys.",
        "subject_id": "jido_action.action"
      },
      {
        "file": ".spec/specs/error_handling.spec.md",
        "id": "jido_action.error_handling.normalized_errors",
        "priority": "must",
        "stability": "stable",
        "statement": "Jido.Action.Error shall provide concrete exception structs and helper constructors for validation, execution, timeout, configuration, and internal errors, with normalized mapping suitable for cross-package handling.",
        "subject_id": "jido_action.error_handling"
      },
      {
        "file": ".spec/specs/exec.spec.md",
        "id": "jido_action.exec.reliability_controls",
        "priority": "must",
        "stability": "stable",
        "statement": "The execution engine shall apply retries, timeout handling, cancellation cleanup, compensation, telemetry, and instance-scoped supervisor/config behavior where those policies are configured.",
        "subject_id": "jido_action.exec"
      },
      {
        "file": ".spec/specs/exec.spec.md",
        "id": "jido_action.exec.sync_async_engine",
        "priority": "must",
        "stability": "stable",
        "statement": "Jido.Exec shall normalize params and context, execute actions synchronously or asynchronously, and preserve action metadata in the runtime context it passes to actions.",
        "subject_id": "jido_action.exec"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_action.package.core_surface",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall provide Jido.Action, Jido.Exec, Jido.Instruction, Jido.Plan, and Jido.Action.Tool as the core surface for defining actions, executing them, normalizing workflow instructions, planning DAG workflows, and exposing AI-compatible tool definitions.",
        "subject_id": "jido_action.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_action.package.readme_onboarding",
        "priority": "should",
        "stability": "evolving",
        "statement": "The README shall document installation plus quick-start usage for action definition, execution, workflow normalization, and AI tool integration.",
        "subject_id": "jido_action.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_action.package.spec_pr_gate",
        "priority": "should",
        "stability": "evolving",
        "statement": "Pull request CI shall run `mix spec.check` against the pull request base branch so Spec Led current truth and proof stay enforced in review.",
        "subject_id": "jido_action.package"
      },
      {
        "file": ".spec/specs/scaffolding.spec.md",
        "id": "jido_action.scaffolding.examples_and_support",
        "priority": "should",
        "stability": "evolving",
        "statement": "The repository shall include a production-quality Zoi example plus maintainer-facing FAQ and PR triage guides to support adoption and ongoing maintenance.",
        "subject_id": "jido_action.scaffolding"
      },
      {
        "file": ".spec/specs/scaffolding.spec.md",
        "id": "jido_action.scaffolding.install_and_generators",
        "priority": "should",
        "stability": "evolving",
        "statement": "The repository shall ship install and generator Mix tasks that compose Igniter behavior when available and raise clear dependency guidance when Igniter is unavailable.",
        "subject_id": "jido_action.scaffolding"
      },
      {
        "file": ".spec/specs/schema.spec.md",
        "id": "jido_action.schema.safe_tool_translation",
        "priority": "must",
        "stability": "stable",
        "statement": "Schema handling shall translate declared schemas into tool-friendly JSON Schema, bridge supported JSON Schema subsets to Zoi when possible, and avoid unsafe atom creation when processing tool input.",
        "subject_id": "jido_action.schema"
      },
      {
        "file": ".spec/specs/schema.spec.md",
        "id": "jido_action.schema.unified_validation",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall provide one schema adapter that accepts NimbleOptions, Zoi, empty schemas, and JSON Schema maps for validation and key introspection.",
        "subject_id": "jido_action.schema"
      },
      {
        "file": ".spec/specs/tools.spec.md",
        "id": "jido_action.tools.builtin_actions",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall ship reusable tool actions for arithmetic, basic utility operations, filesystem access, HTTP requests, and Lua evaluation.",
        "subject_id": "jido_action.tools"
      },
      {
        "file": ".spec/specs/tools.spec.md",
        "id": "jido_action.tools.policy_integration",
        "priority": "should",
        "stability": "evolving",
        "statement": "Built-in tool actions shall cooperate with execution-policy concerns such as deadline propagation and Lua supervision where the tests exercise those boundaries.",
        "subject_id": "jido_action.tools"
      },
      {
        "file": ".spec/specs/workflow.spec.md",
        "id": "jido_action.workflow.instruction_normalization",
        "priority": "must",
        "stability": "stable",
        "statement": "Jido.Instruction shall normalize modules, tuples, and structs into executable instructions with shared context and execution options.",
        "subject_id": "jido_action.workflow"
      },
      {
        "file": ".spec/specs/workflow.spec.md",
        "id": "jido_action.workflow.plan_and_workflow_execution",
        "priority": "must",
        "stability": "stable",
        "statement": "Jido.Plan, Jido.Tools.Workflow, and Jido.Tools.ActionPlan shall model dependency-aware workflows and execute sequential, branched, parallel, and result-transforming action plans through Jido.Exec.",
        "subject_id": "jido_action.workflow"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.agent_prime_context",
        "priority": "should",
        "stability": "evolving",
        "statement": "The repository shall include a .spec/AGENTS.md that tells agents to start a session with mix spec.prime before editing current truth.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.agents_present",
        "priority": "must",
        "stability": "stable",
        "statement": "The repository shall include a .spec/AGENTS.md that gives local operating guidance for agents working inside the .spec workspace.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.decisions_readme_present",
        "priority": "must",
        "stability": "stable",
        "statement": "The repository shall include a .spec/decisions/README.md that explains when durable ADRs belong in the workspace.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.readme_present",
        "priority": "must",
        "stability": "stable",
        "statement": "The repository shall include a .spec/README.md that explains purpose, layout, and workflow.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.state_generated",
        "priority": "must",
        "stability": "stable",
        "statement": "When indexing and validation run, the workspace shall generate .spec/state.json containing indexed subjects, indexed decisions, and verification state.",
        "subject_id": "spec.system"
      }
    ],
